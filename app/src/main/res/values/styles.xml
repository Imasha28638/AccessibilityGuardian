<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="CyberChip">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">28dp</item>
        <item name="android:paddingHorizontal">12dp</item>
        <item name="android:gravity">center</item>
        <item name="android:background">@drawable/bg_card_soft</item>
        <item name="android:textColor">@color/text_secondary_gray</item>
        <item name="android:textSize">9sp</item>
    </style>

    <style name="NavLabelBase" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">9sp</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="NavLabelActive" parent="NavLabelBase">
        <item name="android:textStyle">bold</item>
        <item name="fontFamily">sans-serif-medium</item>
    </style>

    <style name="NavLabelInactive" parent="NavLabelBase">
        <item name="android:textStyle">normal</item>
        <item name="fontFamily">sans-serif</item>
    </style>
</resources>
