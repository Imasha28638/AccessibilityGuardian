<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:padding="12dp"
    android:background="@drawable/bg_card">

    <View
        android:id="@+id/appIconBg"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/bg_card_soft"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <ImageView
        android:id="@+id/appIcon"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@android:drawable/ic_menu_report_image"
        app:layout_constraintStart_toStartOf="@id/appIconBg"
        app:layout_constraintEnd_toEndOf="@id/appIconBg"
        app:layout_constraintTop_toTopOf="@id/appIconBg"
        app:layout_constraintBottom_toBottomOf="@id/appIconBg"/>

    <LinearLayout
        android:orientation="vertical"
        android:layout_marginStart="12dp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toEndOf="@id/appIconBg"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/appRiskScore">

        <TextView
            android:id="@+id/appName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/text_white"
            android:textSize="12sp"
            android:textStyle="bold"
            tools:text="FlashLight Pro" />

        <TextView
            android:id="@+id/riskLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/risk_critical"
            android:textSize="9sp"
            android:letterSpacing="0.05"
            tools:text="CRITICAL" />
    </LinearLayout>

    <TextView
        android:id="@+id/appRiskScore"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="@color/text_white"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:text="94" />

</androidx.constraintlayout.widget.ConstraintLayout>
