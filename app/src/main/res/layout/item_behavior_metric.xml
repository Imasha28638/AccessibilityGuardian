<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="112dp"
    android:layout_margin="4dp"
    android:orientation="vertical"
    android:padding="10dp"
    android:background="@drawable/bg_metric_item">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/ivMetricIcon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:background="@drawable/bg_metric_icon_chip"
            android:padding="4dp"
            android:src="@drawable/ic_bolt_small"
            app:tint="@color/inspect_orange"
            android:contentDescription="Metric Icon" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/tvMetricDelta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_delta_chip"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:text="+18%"
            android:textColor="@color/inspect_orange"
            android:textSize="9sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvMetricValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="247"
        android:textColor="@color/inspect_text_primary"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvMetricTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="Rapid Click Events"
        android:textColor="@color/inspect_text_secondary"
        android:textSize="10sp" />
</LinearLayout>
