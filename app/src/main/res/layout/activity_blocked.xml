<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_page_gradient"
    android:padding="24dp">

    <LinearLayout
        android:id="@+id/blockedCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:background="@drawable/bg_blocked_card"
        android:elevation="8dp"
        android:orientation="vertical"
        android:padding="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.42">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_blocked_icon_orb"
            android:gravity="center"
            android:padding="14dp">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:contentDescription="@string/blocked_icon_desc"
                android:src="@drawable/ic_block_small"
                app:tint="@color/risk_critical" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvRestrictionLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_warning_pill"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:text="@string/security_restriction_label"
            android:textColor="@color/pill_orange_text"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvBlockedTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/security_restriction_title"
            android:textColor="@color/text_white"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvBlockedMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:lineSpacingExtra="3dp"
            android:text="@string/security_restriction_message"
            android:textColor="@color/text_secondary_gray"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvDetailsLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/security_restriction_details"
            android:textColor="@color/text_white"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvReasonDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_card_soft"
            android:lineSpacingExtra="2dp"
            android:padding="14dp"
            android:textColor="@color/text_secondary_gray"
            android:textSize="13sp"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCloseApp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:minHeight="52dp"
            android:text="@string/close_app"
            android:textAllCaps="false"
            android:textColor="@color/text_white"
            app:backgroundTint="@color/risk_critical"
            app:cornerRadius="16dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
