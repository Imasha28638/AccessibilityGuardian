<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/bg_main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="14dp"
        android:paddingBottom="96dp">

        <!-- Updated Header (bell only + app icon left) -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <!-- Left: App icon + name -->
            <LinearLayout
                android:id="@+id/headerLeft"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/headerActions"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <!-- App Icon -->
                <FrameLayout
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_header_app_icon">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@mipmap/ic_launcher"
                        android:contentDescription="@string/app_name" />
                </FrameLayout>

                <!-- Title/Sub -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvAppName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AccessGuard"
                        android:textColor="@android:color/white"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvAppSub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ACCESSIBILITY MONITOR"
                        android:textAllCaps="true"
                        android:letterSpacing="0.14"
                        android:textColor="@color/ag_text_muted"
                        android:textSize="8sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Right: Bell only -->
            <LinearLayout
                android:id="@+id/headerActions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <FrameLayout
                    android:id="@+id/btnAlerts"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_header_action"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_bell"
                        app:tint="@color/ag_text_secondary" />
                </FrameLayout>

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Service Card -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="@drawable/bg_card"
            android:paddingHorizontal="16dp">

            <View
                android:id="@+id/viewServiceDot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/dot_green"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="12dp"
                app:layout_constraintStart_toEndOf="@id/viewServiceDot"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/swMonitoring">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Monitoring Service"
                    android:textColor="@color/text_white"
                    android:textSize="12sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvServiceStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/service_active"
                    android:textColor="@color/accent_green"
                    android:textSize="10sp"/>
            </LinearLayout>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/swMonitoring"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                app:useMaterialThemeColors="false"
                app:thumbTint="@color/switch_thumb_selector"
                app:trackTint="@color/switch_track_selector"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Stats Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            android:weightSum="3">

            <include layout="@layout/widget_stat_card" android:id="@+id/cardScanned" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
            <View android:layout_width="8dp" android:layout_height="1dp"/>
            <include layout="@layout/widget_stat_card" android:id="@+id/cardThreats" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
            <View android:layout_width="8dp" android:layout_height="1dp"/>
            <include layout="@layout/widget_stat_card" android:id="@+id/cardBlocked" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
        </LinearLayout>

        <!-- Risk Card -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_card"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvRiskTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Overall Risk Score"
                android:textColor="@color/text_white"
                android:textSize="12sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>

            <TextView
                android:id="@+id/tvRiskSub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Last scanned 2 min ago"
                android:textColor="@color/text_secondary_gray"
                android:textSize="9sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvRiskTitle"/>

            <ImageButton
                android:id="@+id/btnRefreshRisk"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/bg_icon_button"
                android:src="@android:drawable/ic_menu_rotate"
                app:tint="@color/text_secondary_gray"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:contentDescription="Refresh risk score"/>

            <com.sliit.isp.accessibilityguardian.ui.SemiGaugeView
                android:id="@+id/gauge"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_marginTop="12dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvRiskSub"/>

            <!-- Axis Labels -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/text_muted_gray"
                android:textSize="8sp"
                app:layout_constraintBottom_toBottomOf="@id/gauge"
                app:layout_constraintStart_toStartOf="@id/gauge"
                android:layout_marginStart="40dp"
                android:layout_marginBottom="30dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="50"
                android:textColor="@color/text_muted_gray"
                android:textSize="8sp"
                app:layout_constraintBottom_toTopOf="@id/gauge"
                app:layout_constraintStart_toStartOf="@id/gauge"
                app:layout_constraintEnd_toEndOf="@id/gauge"
                android:layout_marginTop="40dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="100"
                android:textColor="@color/text_muted_gray"
                android:textSize="8sp"
                app:layout_constraintBottom_toBottomOf="@id/gauge"
                app:layout_constraintEnd_toEndOf="@id/gauge"
                android:layout_marginEnd="40dp"
                android:layout_marginBottom="30dp"/>

            <!-- Legend -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/gauge"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:gravity="center">
                <View android:layout_width="4dp" android:layout_height="4dp" android:background="@drawable/dot_green" android:backgroundTint="@color/risk_low" android:layout_marginEnd="4dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/low" android:textColor="@color/text_secondary_gray" android:textSize="8sp" android:layout_marginEnd="8dp"/>
                <View android:layout_width="4dp" android:layout_height="4dp" android:background="@drawable/dot_green" android:backgroundTint="@color/risk_medium" android:layout_marginEnd="4dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/medium" android:textColor="@color/text_secondary_gray" android:textSize="8sp" android:layout_marginEnd="8dp"/>
                <View android:layout_width="4dp" android:layout_height="4dp" android:background="@drawable/dot_green" android:backgroundTint="@color/risk_high" android:layout_marginEnd="4dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/high" android:textColor="@color/text_secondary_gray" android:textSize="8sp" android:layout_marginEnd="8dp"/>
                <View android:layout_width="4dp" android:layout_height="4dp" android:background="@drawable/dot_green" android:backgroundTint="@color/risk_critical" android:layout_marginEnd="4dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/critical" android:textColor="@color/text_secondary_gray" android:textSize="8sp"/>
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Suspicious Apps Section -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp">

            <TextView
                android:id="@+id/tvSuspTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Suspicious Apps"
                android:textColor="@color/text_white"
                android:textSize="12sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>

            <TextView
                android:id="@+id/tvSuspCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="7 detected"
                android:textColor="@color/text_muted_gray"
                android:textSize="9sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvSuspTitle"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:background="@drawable/bg_icon_button"
                android:gravity="center"
                android:paddingHorizontal="8dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent">
                <ImageView android:layout_width="12dp" android:layout_height="12dp" android:src="@android:drawable/ic_menu_sort_by_size" app:tint="@color/text_secondary_gray"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sort" android:textColor="@color/text_secondary_gray" android:textSize="9sp" android:layout_marginStart="4dp"/>
                <ImageView android:layout_width="10dp" android:layout_height="10dp" android:src="@android:drawable/arrow_down_float" app:tint="@color/text_secondary_gray"/>
            </LinearLayout>

            <!-- Horizontal Chips -->
            <HorizontalScrollView
                android:id="@+id/chipScroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:scrollbars="none"
                app:layout_constraintTop_toBottomOf="@id/tvSuspCount">
                <LinearLayout
                    android:id="@+id/chipGroup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <!-- Custom Chips will go here or be styled Material Chips -->
                    <TextView
                        android:id="@+id/chipAll"
                        style="@style/CyberChip"
                        android:text="@string/all"
                        android:background="@drawable/bg_chip_selected"
                        android:textColor="@color/text_white"/>
                    <TextView
                        android:id="@+id/chipCritical"
                        style="@style/CyberChip"
                        android:text="@string/critical"
                        android:layout_marginStart="6dp"/>
                    <TextView
                        android:id="@+id/chipHigh"
                        style="@style/CyberChip"
                        android:text="@string/high"
                        android:layout_marginStart="6dp"/>
                    <TextView
                        android:id="@+id/chipMedium"
                        style="@style/CyberChip"
                        android:text="@string/medium"
                        android:layout_marginStart="6dp"/>
                    <TextView
                        android:id="@+id/chipLow"
                        style="@style/CyberChip"
                        android:text="@string/low"
                        android:layout_marginStart="6dp"/>
                </LinearLayout>
            </HorizontalScrollView>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerApps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/chipScroll"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>
</ScrollView>
